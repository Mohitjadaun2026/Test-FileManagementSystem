# ============================================================================
# TradeNest - Environment Configuration Template
# ============================================================================
# This is a template file (.env.example).
# To use:
#   1. Copy this file: cp .env.example .env
#   2. Replace all xxxxxx values with your actual credentials
#   3. Never commit the actual .env file to git (it contains secrets)
#
# ============================================================================

# ============================================================================
# Database Configuration
# ============================================================================
# MySQL connection string - AUTO CREATES DATABASE if not exists
DB_URL=jdbc:mysql://localhost:3306/file_load_mgmt?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC

# MySQL username (default: root)
DB_USERNAME=root

# MySQL password - CHANGE THIS to your MySQL password
DB_PASSWORD=xxxxxx

# ============================================================================
# Google OAuth2 Configuration
# ============================================================================
# Get these credentials from: https://console.cloud.google.com/
# Steps:
#   1. Create a project
#   2. Enable Google+ API
#   3. Create OAuth 2.0 credentials (Web application)
#   4. Add authorized redirect URIs:
#      - https://localhost:8080/login/oauth2/code/google
#      - http://localhost:4200/oauth2-callback

# Your Google Client ID
GOOGLE_CLIENT_ID=xxxxxx.apps.googleusercontent.com

# Your Google Client Secret
GOOGLE_CLIENT_SECRET=xxxxxx

# OAuth2 redirect URI (where user is sent after login)
GOOGLE_REDIRECT_URI=https://localhost:8080/login/oauth2/code/google

# ============================================================================
# JWT Configuration
# ============================================================================
# Secret key for signing JWT tokens (minimum 32 characters)
# Generate a random string: Use any random strong password (16+ chars)
JWT_SECRET=xxxxxx_minimum_32_characters_long

# Token expiration time in milliseconds
# 86400000 = 24 hours (recommended)
# 604800000 = 7 days
# 3600000 = 1 hour (for testing)
JWT_EXPIRATION=86400000

# ============================================================================
# Super-Admin Bootstrap Configuration
# ============================================================================
# These credentials create the first super-admin account on startup
# This happens ONLY on first startup (when database is empty)
# After that, these values are IGNORED

# Email for super-admin login
SUPER_ADMIN_EMAIL=superadmin@gmail.com

# Username for super-admin
SUPER_ADMIN_USERNAME=superadmin

# Password for super-admin - CHANGE THIS to a strong password
SUPER_ADMIN_PASSWORD=xxxxxx

# ============================================================================
# Server Configuration
# ============================================================================
# Port for backend API
# HTTP runs on SERVER_PORT
# HTTPS runs on SERVER_PORT
SERVER_PORT=8080

# Enable HTTPS/SSL
# false = HTTP only (development)
# true = HTTPS (production, local development with SSL)
SERVER_SSL_ENABLED=true

# SSL Keystore location (for HTTPS certificates)
SERVER_SSL_KEY_STORE=classpath:keystore-local.pfx

# Password for the keystore file
SERVER_SSL_KEY_STORE_PASSWORD=xxxxxx

# Type of keystore (PKCS12 recommended)
SERVER_SSL_KEY_STORE_TYPE=PKCS12

# Frontend URL (used for CORS and redirects)
FRONTEND_BASE_URL=https://localhost:4200

# ============================================================================
# Email Configuration (Gmail SMTP)
# ============================================================================
# For sending emails (password reset, notifications, etc)
# Using Gmail as SMTP provider

# Gmail SMTP server
MAIL_SMTP_HOST=smtp.gmail.com

# Gmail SMTP port (587 for TLS)
MAIL_SMTP_PORT=587

# Your Gmail email address
# NOTE: Use your email, NOT an app password username
MAIL_SMTP_USERNAME=xxxxxx@gmail.com

# Gmail App Password (NOT your regular Gmail password)
# Steps to generate:
#   1. Enable 2-factor authentication on your Gmail account
#   2. Go to https://myaccount.google.com/apppasswords
#   3. Select "Mail" and "Windows Computer"
#   4. Copy the 16-character app password
MAIL_SMTP_PASSWORD=xxxxxx

# Email address to show in "From" field
MAIL_FROM=xxxxxx@gmail.com

# ============================================================================
# Notes
# ============================================================================
# 1. Never commit the actual .env file with real credentials to git
# 2. Use .env.example as template (all values are xxxxxx)
# 3. Each developer creates their own .env locally
# 4. Use strong passwords (16+ characters)
# 5. Rotate secrets periodically
# 6. Keep .env file secure with proper file permissions

